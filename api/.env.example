# Copy เป็น .env แล้วใส่ค่าจริง — ห้าม commit ค่าจริงลง git
#
# DATABASE_URL — เชื่อมต่อ Postgres ใน docker-compose
DATABASE_URL="postgresql://devlabs:devlabs@localhost:5432/devlabs?schema=public"

# JWT_SECRET — ใช้ sign token (generate ด้วย `openssl rand -base64 32`)
JWT_SECRET="change-me-to-a-long-random-string-minimum-32-chars"

# PORT — port ที่ API จะรัน
PORT=3000

# WEB_ORIGIN — origin ของ frontend สำหรับ CORS
WEB_ORIGIN="http://localhost:5173"

# NODE_ENV — development / production
NODE_ENV=development
